# AWS CDK v2.x - Infraestrutura Serverless para Ad Server
# Este diretório contém toda a infraestrutura como código usando AWS CDK em TypeScript
#
# Comandos principais:
#   npm install          # Instalar dependências
#   npx cdk bootstrap    # Bootstrap do CDK no ambiente AWS
#   npx cdk synth        # Sintetizar CloudFormation
#   npx cdk deploy       # Deploy da infraestrutura
#   npx cdk diff         # Comparar com o que está deployed
#   npm test             # Executar testes
{
  "name": "ad-serverless-cdk",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "test": "jest",
    "cdk": "cdk"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "aws-cdk": "^2.135.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.135.0",
    "constructs": "^10.3.0",
    "dotenv": "^16.4.5",
    "source-map-support": "^0.5.21"
  }
}
